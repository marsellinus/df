# Environment Configuration Example
# Copy to .env and modify as needed

# ============ MinIO Configuration ============
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ============ Logging ============
LOG_LEVEL=INFO

# ============ Services ============
LOG_COLLECTOR_PORT=5000
ANALYZER_PORT=5001
DASHBOARD_PORT=5002

# ============ Database ============
DB_TYPE=sqlite3
DB_PATH=/app/data/forensic.db

# ============ Attack Simulation ============
# Attacker credentials
ATTACKER_USERNAME=attacker1
ATTACKER_PASSWORD=password123

# Normal user credentials
NORMAL_USER_USERNAME=user1
NORMAL_USER_PASSWORD=pass1
